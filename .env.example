# NimbrayAI V90 — Product Platform Edition

APP_NAME=NimbrayAI
APP_PUBLIC_LABEL=NimbrayAI

# Provider IA
# Valeurs: demo, groq, ollama, openrouter, local/auto
AI_PROVIDER=demo
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
SYSTEM_PROMPT_MAX_CHARS=2800

# Groq public beta
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENABLE_ROUTER=true

# Auth / Cloud
ENABLE_AUTH=false
ENABLE_SERVER_STORAGE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sources
ENABLE_FREE_SOURCES=true
ENABLE_LOCAL_KNOWLEDGE=true
ENABLE_USER_KNOWLEDGE=true
ENABLE_MEMORY=true
ENABLE_DOCUMENT_PARSING=true
ENABLE_PDF_PARSE=true
ENABLE_DOCX_PARSE=true

# Sources publiques optionnelles
ENABLE_WIKIPEDIA=true
ENABLE_WIKIDATA=true
ENABLE_OPENLIBRARY=true
ENABLE_ARXIV=true
ENABLE_CROSSREF=true
ENABLE_PUBMED=true
ENABLE_STACKEXCHANGE=true
ENABLE_OFFICIAL_DOCS=true

# UX / sécurité
SHOW_INTERNAL_SOURCES=false
SHOW_RAW_CONTEXT=false
ENABLE_SAFE_MODE=true
NIMBRAY_LANGUAGE=fr
