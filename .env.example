# NimbrayAI V45 — Product Platform Edition

APP_NAME=NimbrayAI
APP_PUBLIC_LABEL=NimbrayAI

# Provider IA
AI_PROVIDER=demo

# Groq public beta
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_ENABLE_ROUTER=true

# Auth / Cloud
ENABLE_AUTH=false
ENABLE_SERVER_STORAGE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sources
ENABLE_FREE_SOURCES=true
ENABLE_LOCAL_KNOWLEDGE=true
ENABLE_USER_KNOWLEDGE=true
ENABLE_MEMORY=true
ENABLE_DOCUMENT_PARSING=true
ENABLE_PDF_PARSE=true
ENABLE_DOCX_PARSE=true

# Sources publiques optionnelles
ENABLE_WIKIPEDIA=true
ENABLE_WIKIDATA=true
ENABLE_OPENLIBRARY=true
ENABLE_ARXIV=true
ENABLE_CROSSREF=true
ENABLE_PUBMED=true
ENABLE_STACKEXCHANGE=true
ENABLE_OFFICIAL_DOCS=true

# UX / sécurité
SHOW_INTERNAL_SOURCES=false
SHOW_RAW_CONTEXT=false
ENABLE_SAFE_MODE=true
NIMBRAY_LANGUAGE=fr

# V91 — Vision upload router
# ENABLE_VISION_UPLOADS=true enables honest server-side routing for image uploads.
# Configure VISION_PROVIDER=openrouter or groq plus VISION_MODEL to activate real image analysis.
ENABLE_VISION_UPLOADS=true
VISION_PROVIDER=
VISION_MODEL=
VISION_MAX_TOKENS=700
MAX_UPLOAD_IMAGE_MB=8
MAX_CHAT_IMAGES=4
MAX_CHAT_DOCUMENTS=4
MAX_CHAT_INLINE_DOCUMENT_CHARS=24000
